{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
	"productName": "Arabic Teleprompter",
	"version": "0.1.0",
	"identifier": "com.arabicteleprompter.desktop",
	"build": {
		"devUrl": "http://localhost:1420",
		"frontendDist": "../build",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"url": "/app",
				"title": "التلقين العربي | Arabic Teleprompter",
				"width": 1200,
				"height": 800,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/256x256.png",
			"icons/512x512.png",
			"icons/icon.icns",
			"icons/icon.ico",
			"icons/icon.png"
		]
	}
}
