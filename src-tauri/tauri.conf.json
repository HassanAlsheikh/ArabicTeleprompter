{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
	"productName": "Arabic Teleprompter",
	"version": "0.1.0",
	"identifier": "com.arabicteleprompter.desktop",
	"build": {
		"devUrl": "http://localhost:1420",
		"frontendDist": "../build",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"url": "/app",
				"title": "التلقين العربي | Arabic Teleprompter",
				"width": 1200,
				"height": 800,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all"
	}
}
